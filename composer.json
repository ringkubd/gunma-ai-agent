{
    "name": "anwar/gunma-ai-agent",
    "description": "AI Agent orchestrator for Gunma Halal Food — OpenAI tool calling, Qdrant vector search, Ollama embeddings",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Anwar",
            "email": "anwar@gunmahalalfood.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/database": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0",
        "illuminate/routing": "^10.0|^11.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Anwar\\GunmaAgent\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Anwar\\GunmaAgent\\GunmaAgentServiceProvider"
            ],
            "aliases": {
                "GunmaAgent": "Anwar\\GunmaAgent\\Facades\\GunmaAgent"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
